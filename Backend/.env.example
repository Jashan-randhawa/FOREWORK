# MongoDB Atlas connection string (required for cloud deployment)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jobport

# JWT secret (generate a random 64-byte hex string)
JWT_SECRET=replace_with_a_secure_random_secret

PORT=5011

# Cloudinary
CLOUD_NAME=your_cloud_name
CLOUD_API=your_cloud_api_key
API_SECRET=your_cloud_api_secret
